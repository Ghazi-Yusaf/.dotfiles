{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "neon_green": "#3EC669",
    "neon_red": "#BF616A",
    "surface_0": "#414559",
    "teal": "#81c8be",
    "rosewater": "#f2d5cf",
    "blue":  "#8CAAEE",
    "peach": "#ef9f76",
    "mauve": "#ca9ee6",
    "red": "#e78284",
    "yellow": "#e5c890"
  },
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "background": "p:surface_0",
          "foreground": "p:teal",
          "leading_diamond": "\ue0b6",
          "options": {
            "style": "mixed"
          },
          "style": "diamond",
          "template": "\ue5ff {{ .Path }}",
          "trailing_diamond": "\ue0b4 ",
          "type": "path"
        },
        {
          "background": "p:surface_0",
          "foreground": "p:rosewater",
          "leading_diamond": "\ue0b6",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "diamond",
          "template": "\ue641 {{ .CurrentDate | date .Format }}",
          "trailing_diamond": "\ue0b4 ",
          "type": "time"
        },
        {
          "background": "p:surface_0",
          "foreground": "p:blue",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:peach{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}",
            "{{ if gt .Ahead 0 }}p:mauve{{ end }}",
            "{{ if gt .Behind 0 }}p:mauve{{ end }}"
          ],
          "leading_diamond": "\ue0b6",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "commit_icon": "\uF417 "
          },
          "style": "diamond",
          "template": "{{ if not .UpstreamGone }}{{ .UpstreamIcon }}  {{ end }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }}",
          "trailing_diamond": "\ue0b4 ",
          "type": "git"
        },
        {
          "foreground": "p:yellow",
          "options": {
            "threshold": 5000
          },
          "style": "plain",
          "template": "\uf520 {{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "foreground": "p:red",
          "style": "plain",
          "template": "\uf00d",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:neon_green",
          "foreground_templates": ["{{ if gt .Code 0 }}p:neon_red{{ end }}"],
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "secondary_prompt": {
    "foreground": "p:neon_green",
    "template": "\u276f\u276f "
  },
  "version": 3
}
